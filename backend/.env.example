# DevDoc AI - Backend Environment Variables
PORT=3000
NODE_ENV=development

# DATABASE_URL: PostgreSQL connection URI string for Supabase or standard PostgreSQL.
# For Supabase, go to Settings -> Database -> Connection string -> URI
# We recommend using the Transaction Pooler (port 6543) with ?sslmode=require
# Format: postgresql://postgres:[your-password]@db.[your-project-ref].supabase.co:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devdoc_ai

# Supabase Client Credentials
# Located in your Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API configuration
GEMINI_API_KEY=your_gemini_api_key_here
